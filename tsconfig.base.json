{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "paths": {
  "@team-4/shadcn": ["dist/libs/shadcn"],
  "@team-4/shadcn/server": ["dist/libs/shadcn/server"]
},
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@my-workspace/source"]
  }
}
