{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "jsx": "preserve",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@team-4/shadcn": ["libs/shadcn/src/index.ts"],
      "@team-4/shadcn/server": ["libs/shadcn/src/server.ts"]
    },
    "types": ["node", "react", "react-dom"],
    "outDir": "dist",
    "rootDir": "../.."
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/**/*.js",
    "app/**/*.jsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "components/**/*.js",
    "components/**/*.jsx",
    "features/**/*.ts",
    "features/**/*.tsx",
    "features/**/*.js",
    "features/**/*.jsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "lib/**/*.js",
    "lib/**/*.jsx",
    "../../apps/ebms/.next/types/**/*.ts",
    "../../dist/apps/ebms/.next/types/**/*.ts",
    "signature_pad.d.ts",
    "next-env.d.ts"
  ],
  "exclude": [
    "out-tsc",
    "dist",
    "node_modules",
    "jest.config.ts",
    "jest.config.cts",
    "app/**/*.spec.ts",
    "app/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    ".next",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ]
}
